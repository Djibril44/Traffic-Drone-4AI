@dataclass
class VehicleConfig:
    """Configuration centralisée de l'application"""
    # Modèle YOLO
    confidence_threshold: float = 0.25
    nms_threshold: float = 0.45
    frame_skip: int = 1
    
    # Suivi
    track_smoothness: float = 0.55
    track_max_age: int = 30
    track_distance_threshold: float = 1.8
    
    # Calibration pour la vitesse
    calibration_factor: float = 0.05
    
    # Affichage
    show_tracks: bool = True
    show_bboxes: bool = True
    show_ids: bool = True
    show_speed: bool = True
    show_distance: bool = True
    
    # Performance
    detection_history_size: int = 100
    processing_time_window: int = 30
    fps_smoothing: float = 0.8


VEHICLE_CLASSES = {
    0: "Personne",
    1: "Vélo",
    2: "Voiture",
    3: "Moto",
    5: "Bus",
    7: "Camion",
}

ENABLED_CLASSES_DEFAULT = {2, 3, 5, 7}

VEHICLE_COLORS = {
    "Voiture": (235, 152, 41),
    "Moto": (60, 76, 231),
    "Bus": (15, 196, 241),
    "Camion": (173, 68, 142),
    "Vélo": (96, 174, 39),
    "Personne": (141, 140, 127),
}


