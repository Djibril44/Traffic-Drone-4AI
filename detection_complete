def parse_time(time_str):
    if not time_str:
        return datetime.now().time()
    try:
        return datetime.strptime(time_str, "%H:%M:%S").time()
    except ValueError:
        try:
            return datetime.strptime(time_str, "%H:%M").time()
        except ValueError:
            return datetime.now().time()


